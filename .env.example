APP_NAME=Collectinfos
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# À mettre à jour lors du déploiement VPS (domaine HTTPS obligatoire pour Djomy)
APP_URL=http://localhost

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=collectinfos
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# SMTP LWS — serveur sortant : mail68.lwspanel.com (port 465 SSL)
MAIL_MAILER=smtp
MAIL_SCHEME=smtps
MAIL_HOST=mail68.lwspanel.com
MAIL_PORT=465
MAIL_USERNAME=collectinfos@silycor.xyz
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=collectinfos@silycor.xyz
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Djomy production — https://developers.djomy.africa/
DJOMY_ENABLED=false
DJOMY_BASE_URL=https://api.djomy.africa
DJOMY_CLIENT_ID=
DJOMY_CLIENT_SECRET=
DJOMY_PARTNER_DOMAIN=
DJOMY_COUNTRY_CODE=GN
DJOMY_CURRENCY=GNF
DJOMY_VERIFY_SSL=true
# Obligatoire : URLs HTTPS pour retour/annulation (Djomy refuse http://localhost)
DJOMY_CALLBACK_BASE_URL=https://collectinfos.org

# Conversion catalogue (EUR) → paiement Djomy (GNF). Ex. 1 € = 10 000 GNF
EUR_TO_GNF_RATE=10000
